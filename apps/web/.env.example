# Next.js BFF Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================================
# Cookie Configuration
# ============================================================================
# Name of the authentication cookie (HttpOnly)
AUTH_COOKIE_NAME=auth_token

# ============================================================================
# Auth Backend Selection
# ============================================================================
# Choose which backend to use for authentication: 'laravel' | 'symfony' | 'node'
# You can still switch backend dynamically at runtime via routes:
# /laravel, /symfony, /hono (isolated cookies per backend)
AUTH_BACKEND=laravel

# ============================================================================
# Laravel API Configuration (port 8000)
# ============================================================================
LARAVEL_API_URL=http://localhost:8000

# ============================================================================
# Symfony API Configuration (port 8002)
# ============================================================================
# Uses BetterAuth with Bearer tokens
SYMFONY_API_URL=http://localhost:8002
# Auth endpoint prefix (default: /api/v1/auth)
SYMFONY_AUTH_PREFIX=/api/v1/auth

# ============================================================================
# Node.js API Configuration (port 8003)
# ============================================================================
# Compatible with Hono, Express, Fastify, etc.
NODE_API_URL=http://localhost:8003
# Auth endpoint prefix - must match API_VERSION in api-hono (default: /api/v1/auth)
NODE_AUTH_PREFIX=/api/v1/auth

# ============================================================================
# AI Configuration
# ============================================================================
# Default AI provider: anthropic | openai | google | mistral
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-20250514

# Public env vars for client-side defaults
NEXT_PUBLIC_AI_PROVIDER=anthropic
NEXT_PUBLIC_AI_MODEL=claude-sonnet-4-20250514

# API Keys (at least one required for AI chat)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
MISTRAL_API_KEY=
