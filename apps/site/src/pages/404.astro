---
import MainLayout from "../layouts/main.astro"
---

<MainLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <div class="flex min-h-[60vh] flex-col items-center justify-center text-center">
    <h1 class="text-6xl font-bold text-foreground">404</h1>
    <p class="mt-4 text-xl text-muted-foreground">Page not found</p>
    <p class="mt-2 text-muted-foreground">The page you're looking for doesn't exist or has been moved.</p>
    <a
      href="/"
      class="mt-8 inline-flex items-center rounded-lg bg-primary px-6 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
    >
      Back to Home
    </a>
  </div>
</MainLayout>
