---
const modules = [
  {
    name: "Admin Dashboard",
    color: "violet",
    colorClass: "text-violet-400",
    bgClass: "bg-violet-primary/10",
    features: [
      "User & role management (RBAC)",
      "Product & order CRUD",
      "Revenue analytics & charts",
      "Customer segments",
      "Inventory management",
      "Review moderation",
    ],
  },
  {
    name: "E-commerce",
    color: "amber",
    colorClass: "text-amber-400",
    bgClass: "bg-amber-500/10",
    features: [
      "Product catalog & categories",
      "Shopping cart (persistent)",
      "Order checkout & history",
      "Product reviews & ratings",
      "Search & filtering",
      "Stock management",
    ],
  },
  {
    name: "SaaS Platform",
    color: "sky",
    colorClass: "text-sky-400",
    bgClass: "bg-sky-500/10",
    features: [
      "Multi-tenant organizations",
      "Plans & subscriptions",
      "Invoices & billing",
      "Team member management",
      "Usage tracking & limits",
      "Organization settings",
    ],
  },
  {
    name: "Support Center",
    color: "emerald",
    colorClass: "text-emerald-400",
    bgClass: "bg-emerald-500/10",
    features: [
      "Conversation threads",
      "Real-time messaging",
      "Canned responses",
      "Agent queue & assignment",
      "Satisfaction ratings",
      "Stats & analytics",
    ],
  },
];
---

<section id="modules" class="py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mb-16 text-center">
      <h2 class="mb-4 text-3xl font-bold tracking-tight sm:text-4xl">
        Production-ready <span class="gradient-text">domain modules</span>
      </h2>
      <p class="mx-auto max-w-2xl text-lg text-text-muted">
        Each module is a complete vertical slice — backend endpoints, frontend pages, and admin tools. Pick what you need.
      </p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2">
      {modules.map((mod) => (
        <div class="rounded-xl border border-border-subtle bg-surface-card p-6 transition-all hover:border-violet-primary/30 hover:bg-surface-card-hover">
          <h3 class={`mb-4 text-lg font-semibold ${mod.colorClass}`}>
            {mod.name}
          </h3>
          <ul class="space-y-2">
            {mod.features.map((feature) => (
              <li class="flex items-start gap-2.5 text-sm">
                <svg class={`mt-0.5 h-4 w-4 shrink-0 ${mod.colorClass}`} fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-text-muted">{feature}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <p class="mt-8 text-center text-sm text-text-muted">
      All modules are implemented across all 3 backends (Laravel, Symfony, Hono) with identical API contracts.
    </p>
  </div>
</section>
