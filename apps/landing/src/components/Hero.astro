---
---

<section class="relative overflow-hidden pt-32 pb-20 md:pt-40 md:pb-32">
  <!-- Background effects -->
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute top-0 left-1/2 h-[600px] w-[800px] -translate-x-1/2 rounded-full bg-violet-primary/10 blur-[120px]"></div>
    <div class="absolute top-40 left-1/4 h-[400px] w-[400px] rounded-full bg-indigo-primary/8 blur-[100px]"></div>
    <div class="grid-pattern absolute inset-0"></div>
  </div>

  <div class="relative mx-auto max-w-5xl px-6 text-center">
    <!-- Badge -->
    <div class="mb-8 inline-flex items-center gap-2 rounded-full border border-violet-primary/30 bg-violet-primary/10 px-4 py-1.5 text-sm text-violet-300">
      <span class="h-1.5 w-1.5 rounded-full bg-violet-400"></span>
      v0.1.0 — Open Source
    </div>

    <!-- Headline -->
    <h1 class="mb-6 text-4xl font-extrabold leading-tight tracking-tight sm:text-5xl md:text-6xl lg:text-7xl">
      Build Full-Stack Apps with<br />
      <span class="gradient-text">Domain-Driven Modules</span>
    </h1>

    <!-- Subline -->
    <p class="mx-auto mb-10 max-w-2xl text-lg leading-relaxed text-text-muted md:text-xl">
      Pick a preset, choose your stack, get production-ready modules — Auth, Shop, SaaS, Support — with a secure BFF proxy layer. Ship in minutes.
    </p>

    <!-- CTA Buttons -->
    <div class="mb-14 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="#quickstart"
        class="inline-flex items-center gap-2 rounded-xl bg-violet-primary px-7 py-3.5 text-base font-semibold text-white transition-all hover:bg-violet-600 hover:shadow-xl hover:shadow-violet-primary/25"
      >
        Get Started
        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      <a
        href="https://github.com"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-xl border border-border-subtle bg-surface-card px-7 py-3.5 text-base font-semibold text-white transition-all hover:border-violet-primary/40 hover:bg-surface-card-hover"
      >
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
        </svg>
        View on GitHub
      </a>
    </div>

    <!-- Code snippet -->
    <div class="glow mx-auto max-w-lg">
      <div class="code-block">
        <div class="flex items-center gap-2 border-b border-border-subtle px-4 py-3">
          <span class="h-3 w-3 rounded-full bg-red-500/60"></span>
          <span class="h-3 w-3 rounded-full bg-yellow-500/60"></span>
          <span class="h-3 w-3 rounded-full bg-green-500/60"></span>
          <span class="ml-3 text-xs text-text-muted">Terminal</span>
        </div>
        <pre><code><span class="text-text-muted">$</span> <span class="text-violet-300">bunx</span> <span class="text-white">create-headless-app</span>

<span class="text-text-muted">? Choose a preset</span>
<span class="text-violet-300">  ● E-commerce</span>  <span class="text-text-muted">— Shop, Cart, Orders, Admin</span>
<span class="text-text-muted">  ○ SaaS        — Orgs, Billing, Teams</span>
<span class="text-text-muted">  ○ Admin       — Dashboard, RBAC, Analytics</span>
<span class="text-text-muted">  ○ Landing     — Minimal auth setup</span>

<span class="text-text-muted">? Frontend</span>
<span class="text-violet-300">  ● Next.js</span> <span class="text-text-muted">— App Router + shadcn/ui</span>
<span class="text-text-muted">  ○ TanStack Start — Vite + TanStack Router</span>

<span class="text-text-muted">? Backend</span>
<span class="text-violet-300">  ● Laravel</span>
<span class="text-text-muted">  ○ Symfony</span>
<span class="text-text-muted">  ○ Hono</span></code></pre>
      </div>
    </div>
  </div>
</section>
