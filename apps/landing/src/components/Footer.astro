---
const links = [
  { href: "https://github.com/headless-kit/headless-kit", label: "GitHub" },
  { href: "/docs", label: "Documentation" },
  { href: "#discord", label: "Discord" },
];
---

<footer class="border-t border-border-subtle bg-surface-darker py-12">
  <div class="mx-auto max-w-6xl px-6">
    <div class="flex flex-col items-center justify-between gap-6 sm:flex-row">
      <div class="flex items-center gap-2.5">
        <svg class="h-6 w-6" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="32" height="32" rx="6" fill="#7c3aed" />
          <path d="M8 10h6v12H8zM18 10h6v12h-6z" fill="white" opacity="0.9" />
          <path d="M14 14l4 0" stroke="white" stroke-width="2" stroke-linecap="round" />
          <path d="M14 18l4 0" stroke="white" stroke-width="2" stroke-linecap="round" />
        </svg>
        <span class="text-sm font-semibold">Headless Kit</span>
      </div>

      <div class="flex items-center gap-6">
        {links.map((link) => (
          <a
            href={link.href}
            class="text-sm text-text-muted transition-colors hover:text-white"
            target={link.href.startsWith("http") ? "_blank" : undefined}
            rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
          >
            {link.label}
          </a>
        ))}
      </div>

      <div class="text-center sm:text-right">
        <p class="text-xs text-text-muted">
          Built with Astro, Tailwind CSS, and lots of coffee.
        </p>
        <p class="mt-1 text-xs text-text-muted">
          &copy; {new Date().getFullYear()} Headless Kit. All rights reserved.
        </p>
      </div>
    </div>
  </div>
</footer>
