---
const links = [
  { href: "#features", label: "Features" },
  { href: "#modules", label: "Modules" },
  { href: "#architecture", label: "Architecture" },
  { href: "#backends", label: "Backends" },
  { href: "/docs", label: "Docs" },
  { href: "#pricing", label: "Pricing" },
];
---

<nav class="fixed top-0 z-50 w-full border-b border-border-subtle/50 bg-surface-darker/80 backdrop-blur-xl">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
    <a href="/" class="flex items-center gap-2.5 text-lg font-bold tracking-tight">
      <svg class="h-7 w-7" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="32" height="32" rx="6" fill="#7c3aed" />
        <path d="M8 10h6v12H8zM18 10h6v12h-6z" fill="white" opacity="0.9" />
        <path d="M14 14l4 0" stroke="white" stroke-width="2" stroke-linecap="round" />
        <path d="M14 18l4 0" stroke="white" stroke-width="2" stroke-linecap="round" />
      </svg>
      <span>Headless Kit</span>
    </a>

    <div class="hidden items-center gap-8 md:flex">
      {links.map((link) => (
        <a
          href={link.href}
          class="text-sm text-text-muted transition-colors hover:text-white"
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-3">
      <a
        href="https://github.com/headless-kit/headless-kit"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden text-sm text-text-muted transition-colors hover:text-white sm:inline-block"
      >
        GitHub
      </a>
      <a
        href="#quickstart"
        class="rounded-lg bg-violet-primary px-4 py-2 text-sm font-medium text-white transition-all hover:bg-violet-600 hover:shadow-lg hover:shadow-violet-primary/25"
      >
        Get Started
      </a>

      <!-- Mobile hamburger button -->
      <button
        id="mobile-menu-btn"
        class="flex items-center justify-center rounded-lg p-2 text-text-muted transition-colors hover:text-white md:hidden"
        aria-label="Open menu"
      >
        <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile slide-out menu -->
<div id="mobile-menu-overlay" class="fixed inset-0 z-50 hidden">
  <!-- Backdrop -->
  <div id="mobile-menu-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>

  <!-- Panel -->
  <div
    id="mobile-menu-panel"
    class="absolute top-0 right-0 h-full w-72 translate-x-full border-l border-border-subtle bg-surface-darker transition-transform duration-300 ease-in-out"
  >
    <div class="flex items-center justify-between border-b border-border-subtle px-6 py-5">
      <span class="text-lg font-bold">Menu</span>
      <button
        id="mobile-menu-close"
        class="flex items-center justify-center rounded-lg p-2 text-text-muted transition-colors hover:text-white"
        aria-label="Close menu"
      >
        <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div class="flex flex-col gap-1 px-4 py-4">
      {links.map((link) => (
        <a
          href={link.href}
          class="mobile-menu-link rounded-lg px-3 py-2.5 text-sm text-text-muted transition-colors hover:bg-surface-card hover:text-white"
        >
          {link.label}
        </a>
      ))}
      <hr class="my-2 border-border-subtle" />
      <a
        href="https://github.com/headless-kit/headless-kit"
        target="_blank"
        rel="noopener noreferrer"
        class="mobile-menu-link rounded-lg px-3 py-2.5 text-sm text-text-muted transition-colors hover:bg-surface-card hover:text-white"
      >
        GitHub
      </a>
    </div>
  </div>
</div>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const overlay = document.getElementById("mobile-menu-overlay");
  const backdrop = document.getElementById("mobile-menu-backdrop");
  const panel = document.getElementById("mobile-menu-panel");
  const closeBtn = document.getElementById("mobile-menu-close");
  const menuLinks = document.querySelectorAll(".mobile-menu-link");

  function openMenu() {
    overlay?.classList.remove("hidden");
    requestAnimationFrame(() => {
      panel?.classList.remove("translate-x-full");
    });
  }

  function closeMenu() {
    panel?.classList.add("translate-x-full");
    setTimeout(() => {
      overlay?.classList.add("hidden");
    }, 300);
  }

  btn?.addEventListener("click", openMenu);
  closeBtn?.addEventListener("click", closeMenu);
  backdrop?.addEventListener("click", closeMenu);
  menuLinks.forEach((link) => link.addEventListener("click", closeMenu));
</script>
