---
import { getMessages, getLocale } from "@/i18n"

type Props = {
  prev: { slug: string; label: string } | null
  next: { slug: string; label: string } | null
}

const { prev, next } = Astro.props
const locale = getLocale(Astro.currentLocale)
const t = getMessages(locale)
---

<nav class="mt-16 flex items-stretch gap-4 border-t border-border pt-6" aria-label="Page navigation">
  {prev ? (
    <a
      href={`/docs/${prev.slug}`}
      class="group flex flex-1 flex-col rounded-lg border border-border p-4 transition-colors hover:border-primary/30 hover:bg-primary/5"
    >
      <span class="text-[10px] uppercase tracking-widest text-muted-foreground">{t.docs.previous}</span>
      <span class="mt-1 text-sm text-foreground group-hover:text-primary transition-colors">
        ← {prev.label}
      </span>
    </a>
  ) : <div class="flex-1" />}

  {next ? (
    <a
      href={`/docs/${next.slug}`}
      class="group flex flex-1 flex-col items-end rounded-lg border border-border p-4 transition-colors hover:border-primary/30 hover:bg-primary/5"
    >
      <span class="text-[10px] uppercase tracking-widest text-muted-foreground">{t.docs.next}</span>
      <span class="mt-1 text-sm text-foreground group-hover:text-primary transition-colors">
        {next.label} →
      </span>
    </a>
  ) : <div class="flex-1" />}
</nav>
