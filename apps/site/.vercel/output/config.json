{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin(?:/(.*?))?/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth(?:/(.*?))?/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/checkout/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/webhooks/stripe/?$",
			"dest": "_render"
		},
		{
			"src": "^/auth/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/auth/logout/?$",
			"dest": "_render"
		},
		{
			"src": "^/auth/register/?$",
			"dest": "_render"
		},
		{
			"src": "^/checkout/success/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/admin/licenses/create/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/admin/licenses/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/admin/revenue/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/admin/settings/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/admin/users/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/admin/users/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/admin/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/billing/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/downloads/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/license/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/?$",
			"dest": "_render"
		},
		{
			"src": "^/fr/auth/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/fr/auth/register/?$",
			"dest": "_render"
		},
		{
			"src": "^/fr/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "/404.html",
			"status": 404
		}
	]
}